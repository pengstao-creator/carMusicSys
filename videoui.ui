  <property name="styleSheet">
   <string notr="true">QWidget#videoUi {
    background: #0b0c0f;
}

QFrame#playerSurface {
    background: #000000;
    border-radius: 12px;
}

QFrame#topOverlay {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
        stop:0 rgba(0,0,0,170), stop:1 rgba(0,0,0,0));
}

QFrame#bottomOverlay {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
        stop:0 rgba(0,0,0,0), stop:1 rgba(0,0,0,185));
}

QLabel#videoTitleLabel {
    color: rgba(255, 255, 255, 235);
    font-size: 14px;
    font-weight: 600;
}

QLabel#timeCurrentLabel, QLabel#timeTotalLabel {
    color: rgba(255, 255, 255, 200);
    font-size: 12px;
}

QToolButton {
    background: transparent;
    border: none;
}

QToolButton:pressed {
    background: rgba(255, 255, 255, 18);
    border-radius: 10px;
}

QSlider::groove:horizontal {
    height: 4px;
    background: rgba(255, 255, 255, 30);
    border-radius: 2px;
}

QSlider::sub-page:horizontal {
    background: rgba(0, 161, 214, 220);
    border-radius: 2px;
}

QSlider::handle:horizontal {
    width: 12px;
    margin: -5px 0;
    border-radius: 6px;
    background: rgba(255, 255, 255, 240);
}

QFrame#playlistPanel {
    background: rgba(15, 20, 26, 210);
    border: 1px solid rgba(255, 255, 255, 28);
    border-radius: 12px;
}

QLabel#playlistTitleLabel {
    color: rgba(255, 255, 255, 220);
    font-size: 13px;
    font-weight: 600;
}

QListWidget#playlistListWidget {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 210);
}

QListWidget#playlistListWidget::item {
    padding: 6px 4px;
}

QListWidget#playlistListWidget::item:selected {
    background: rgba(0, 161, 214, 80);
    border-radius: 6px;
}</string>
