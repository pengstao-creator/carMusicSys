   <string notr="true">QWidget#videoUi { background: #0f1419; }

QWidget#playerSurface {
    background: #000000;
    border-radius: 14px;
}

QWidget#controlsBar {
    background: rgba(15, 20, 25, 190);
    border-top: 1px solid rgba(255, 255, 255, 14);
}

QLabel#titleLabel {
    color: rgba(232, 238, 245, 220);
    font-size: 14px;
    font-weight: 600;
}

QLabel#timeLabel {
    color: rgba(232, 238, 245, 170);
    font-size: 12px;
}

QToolButton {
    background: transparent;
    border: none;
}

QToolButton:pressed {
    background: rgba(255, 255, 255, 18);
    border-radius: 10px;
}

QSlider::groove:horizontal {
    height: 6px;
    background: rgba(255, 255, 255, 18);
    border-radius: 3px;
}

QSlider::sub-page:horizontal {
    background: rgba(82, 194, 255, 200);
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 14px;
    margin: -5px 0;
    border-radius: 7px;
    background: rgba(230, 248, 255, 240);
}</string>
