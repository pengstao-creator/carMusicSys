  <property name="styleSheet">
   <string notr="true">QWidget#musicUi {
    background-color: #0f1115;
}

QWidget#topWidget,
QWidget#controlWidget,
QWidget#playlistWidget {
    background-color: rgba(24, 24, 24, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
}

QLabel#albumCover {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    color: #cfcfcf;
}

QLabel#songTitle {
    font-size: 18px;
    font-weight: bold;
    color: #f2f2f2;
}

QLabel#artistName {
    font-size: 14px;
    color: #cfcfcf;
}

QLabel#albumName {
    font-size: 12px;
    color: #9a9a9a;
}

QLabel#currentTime,
QLabel#totalTime,
QLabel#volumeLabel {
    color: #cfcfcf;
}

QPushButton {
    color: #eaeaea;
    background-color: transparent;
    border: none;
    padding: 6px 10px;
}

QPushButton:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-radius: 10px;
}

QPushButton#playButton {
    background-color: #1DB954;
    color: #0b0c0d;
    border-radius: 22px;
    min-width: 44px;
    min-height: 44px;
    font-size: 22px;
    font-weight: bold;
}

QPushButton#playButton:hover {
    background-color: #22c35e;
}

QToolButton#exitButton {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 16px;
    min-width: 32px;
    min-height: 32px;
    color: #eaeaea;
    font-size: 18px;
}

QToolButton#exitButton:hover {
    background-color: rgba(255, 255, 255, 0.10);
}

QLineEdit {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 16px;
    padding: 6px 10px;
    color: #f2f2f2;
}

QLineEdit::placeholder {
    color: #9a9a9a;
}

QListWidget {
    background-color: rgba(0, 0, 0, 0.20);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 12px;
    color: #f2f2f2;
}

QListWidget::item {
    padding: 10px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

QListWidget::item:hover {
    background-color: rgba(255, 255, 255, 0.06);
}

QListWidget::item:selected {
    background-color: #1DB954;
    color: #0b0c0d;
}

QSlider::groove:horizontal {
    border: 1px solid rgba(255, 255, 255, 0.10);
    height: 6px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #1DB954;
    border: 1px solid #1DB954;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    margin: -4px 0;
}</string>
